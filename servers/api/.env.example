# API server environment variables.
# Copy this to .env and fill in the values for local development.
# In production, use AWS SSM Parameter Store — see deploy/load-ssm-secrets.sh
# and docs/security.md for the recommended secret management approach.
#
# IMPORTANT: .env files are gitignored. Never commit a file with real credentials.

MASTER_KEY="change-me-use-a-long-random-string"
DB_USER="python_pvp_admin"
DB_PASSWORD="change-me"
DB_HOST="localhost"
DB_PORT="5433"
DB_NAME="python_pvp"

# AWS region for SQS SDK client
AWS_REGION="ap-southeast-1"

# SQS queue URL — set after creating the queue (see AWS resource.md)
BATTLE_QUEUE_URL="https://sqs.ap-southeast-1.amazonaws.com/<account>/python-pvp-battle-queue"

# Simulator service token (from database/4. service-account.sql)
SIM_API_TOKEN="00000000-0000-0000-0000-000000000002"